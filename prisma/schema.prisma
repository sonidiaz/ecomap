generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  orgMembers    OrgMember[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// EcoMap Models
model Organization {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  logo            String?
  description     String?           @db.Text
  city            String?
  country         String?
  lat             Float?
  lng             Float?
  tags            String[]          @default([])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         OrgMember[]
  collaborators   Collaborator[]
  proximityScores ProximityScore[]
  importLogs      ImportLog[]

  @@index([slug])
}

enum OrgRole {
  ADMIN
  EDITOR
  VIEWER
}

model OrgMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole      @default(VIEWER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

enum CollaboratorType {
  PERSON
  ORGANIZATION
  PROJECT
}

model Collaborator {
  id               String            @id @default(cuid())
  orgId            String
  name             String
  email            String?
  phone            String?
  address          String?
  city             String?
  country          String?
  lat              Float?
  lng              Float?
  type             CollaboratorType  @default(PERSON)
  company          String?
  tags             String[]          @default([])
  notes            String?           @db.Text
  collabActive     Boolean           @default(false)
  collabPast       Boolean           @default(false)
  contactFrequency Int               @default(0) // 0-5 scale
  isArchived       Boolean           @default(false)
  photoUrl         String?
  extra            Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  proximityScores  ProximityScore[]

  @@unique([orgId, email])
  @@index([orgId, isArchived])
  @@index([email])
}

enum Orbit {
  CORE      // >= 70
  MID       // 40-69
  PERIPHERY // < 40
}

model ProximityScore {
  id                 String       @id @default(cuid())
  orgId              String
  collaboratorId     String
  scoreTotal         Float
  scoreCollabActive  Float
  scoreCollabPast    Float
  scoreGeo           Float
  scoreFrequency     Float
  scoreAffinity      Float
  orbit              Orbit
  calculatedAt       DateTime     @default(now())
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  collaborator       Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@unique([collaboratorId])
  @@index([orgId, orbit])
}

model ImportLog {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  filename     String
  rowsTotal    Int
  rowsImported Int
  rowsSkipped  Int
  errorDetails Json?
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}
